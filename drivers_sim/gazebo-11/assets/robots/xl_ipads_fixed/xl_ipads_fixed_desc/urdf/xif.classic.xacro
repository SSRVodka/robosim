<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"
  name="xl_ipads_fixed">
  
  <xacro:include filename="$(find xl_ipads_fixed_desc)/urdf/base.urdf.xacro" />
  <xacro:include filename="$(find xl_ipads_fixed_desc)/urdf/sensors/imu.urdf.xacro" />
  <xacro:include filename="$(find xl_ipads_fixed_desc)/urdf/sensors/laser.urdf.xacro" />
  <xacro:include filename="$(find xl_ipads_fixed_desc)/urdf/sensors/camera.urdf.xacro" />
  <xacro:include filename="$(find xl_ipads_fixed_desc)/urdf/actuator/wheel.urdf.xacro" />
  <xacro:include filename="$(find xl_ipads_fixed_desc)/urdf/actuator/caster.urdf.xacro" />
  <xacro:include filename="$(find xl_ipads_fixed_desc)/urdf/xif.ros2_control.classic.xacro" />
  <xacro:include filename="$(find xl_ipads_fixed_desc)/urdf/plugins/gazebo_sensor_plugin.classic.xacro" />

  <xacro:base_xacro length="0.12" radius="0.1" />
  <xacro:imu_xacro xyz="0 0 0.02" />
  <xacro:laser_xacro xyz="0.3 0 0.25" />
  <xacro:camera_xacro xyz="0.24 0 1.30" rpy="0 ${pi/4} 0" />
  <xacro:wheel_xacro wheel_name="left" xyz="0 0.25 -0.06" />
  <xacro:wheel_xacro wheel_name="right" xyz="0 -0.25 -0.06" />
  <xacro:caster_xacro caster_name="front" xyz="0.23 0.0 -0.076" />
  <xacro:caster_xacro caster_name="back" xyz="-0.23 0.0 -0.076" />
  <!-- 3 轮模式 -->
  <!-- <xacro:wheel_xacro wheel_name="left" xyz="-0.2 0.25 -0.06" />
  <xacro:wheel_xacro wheel_name="right" xyz="-0.2 -0.25 -0.06" />
  <xacro:caster_xacro caster_name="front" xyz="0.32 0.0 -0.076" /> -->
  
  <xacro:xl_ipads_fixed_ros2_control />
  <xacro:gazebo_sensor_plugin />
</robot>