#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
    subLayers = [
        @layers/scenario.usda@,
        @layers/task.usda@,
        @layers/physics.usda@,
        @layers/backends/mujoco.usda@,
        @layers/backends/pybullet.usda@,
        @layers/backends/gazebo.usda@
    ]
)

over "World" (
    prepend variantSets = "physicsBackend"
    variants = {
        string physicsBackend = "mujoco"
    }
)
{
}
