#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
    subLayers = [
        @scenario.usda@,
        @task.usda@,
        @physics.usda@,
        @backends/mujoco.usda@,
        @backends/pybullet.usda@,
        @backends/gazebo.usda@
    ]
)

over "World" (
    prepend variantSets = "physicsBackend"
    variants = {
        string physicsBackend = "mujoco"
    }
)
{
}

