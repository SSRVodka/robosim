#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "World" (
    prepend apiSchemas = ["RobosimCsdRootAPI", "RobosimRandomizationAPI"]
    variants = {
        string physicsBackend = "mujoco"
    }
    prepend variantSets = "physicsBackend"
)
{
    custom string robosim:csd:id = "csd_low_gravity_static_layout_0001"
    custom string robosim:csd:schemaVersion = "0.2"
    custom string robosim:csd:taskInstanceId = "task_low_gravity_static_layout_0001"
    custom string robosim:csd:worldTemplateId = "env_low_gravity_floor"
    custom int64 robosim:randomization:seed = 43

    def Xform "Environment" (
        prepend apiSchemas = ["RobosimEntityAPI"]
    )
    {
        custom string robosim:entity:assetId = "env_low_gravity_floor"
        custom string robosim:entity:id = "environment"
        custom token robosim:entity:role = "environment"
        custom bool robosim:entity:static = 1
    }

    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, 0, -1)
        float physics:gravityMagnitude = 1.62
    }

    def Camera "world_camera"
    {
        quatd xformOp:orient = (1, 0, 0, 0)
        quatd xformOp:orient:xyaxes = (0.6023329525682853, 0.3703984533585038, 0.37039845335850374, 0.6023329525682856)
        double3 xformOp:translate = (1.4, 0, 1.1)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:orient:xyaxes"]
    }

    def DistantLight "key_light"
    {
        quatd xformOp:orient = (1, 0, 0, 0)
        double3 xformOp:translate = (0, -1, 3)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient"]
    }

    def Scope "Objects"
    {
        def Xform "tray_static" (
            prepend apiSchemas = ["RobosimEntityAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Materials/object_tray_static>
            float physics:mass = 1.2
            custom string robosim:entity:assetId = "object_tray"
            custom string robosim:entity:id = "tray_static"
            custom token robosim:entity:role = "support"
            custom bool robosim:entity:static = 1
            quatd xformOp:orient = (1, 0, 0, 0)
            double3 xformOp:translate = (0, -0.08, 0.15)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient"]
        }

        def Xform "marker_dynamic" (
            prepend apiSchemas = ["RobosimEntityAPI", "PhysicsMassAPI", "PhysicsRigidBodyAPI", "MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Materials/object_marker_dynamic>
            float physics:mass = 0.05
            bool physics:rigidBodyEnabled = 1
            custom string robosim:entity:assetId = "object_marker"
            custom string robosim:entity:id = "marker_dynamic"
            custom token robosim:entity:role = "interactive_object"
            custom bool robosim:entity:static = 0
            quatd xformOp:orient = (1, 0, 0, 0)
            double3 xformOp:translate = (0.08, 0.08, 0.2)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient"]
        }
    }

    def "Materials"
    {
        def Material "object_tray_static" (
            prepend apiSchemas = ["PhysicsMaterialAPI"]
        )
        {
            float physics:dynamicFriction = 0.9
            float physics:staticFriction = 0.9
        }

        def Material "object_marker_dynamic" (
            prepend apiSchemas = ["PhysicsMaterialAPI"]
        )
        {
            float physics:dynamicFriction = 0.65
            float physics:staticFriction = 0.65
        }
    }

    def Scope "Task" (
        prepend apiSchemas = ["RobosimTaskAPI"]
    )
    {
        custom string robosim:task:objective = "verify non-default gravity with static and dynamic rigid objects"
    }

    def Scope "Relationships"
    {
        def RobosimRelationship "rel_marker_avoid_tray"
        {
            custom double robosim:relationship:minDistanceM = 0.05
            custom rel robosim:relationship:object = </World/Objects/tray_static>
            custom rel robosim:relationship:subject = </World/Objects/marker_dynamic>
            custom double robosim:relationship:tolerance = 0
            custom token robosim:relationship:type = "avoid_contact"
        }
    }
    variantSet "physicsBackend" = {
        "gazebo" {

        }
        "mujoco" {

        }
        "pybullet" {

        }
    }
}

