#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "World" (
    prepend apiSchemas = ["RobosimCsdRootAPI", "RobosimRandomizationAPI"]
    variants = {
        string physicsBackend = "mujoco"
    }
    prepend variantSets = "physicsBackend"
)
{
    custom string robosim:csd:id = "csd_visual_tabletop_regions_0001"
    custom string robosim:csd:schemaVersion = "0.2"
    custom string robosim:csd:taskInstanceId = "task_visual_tabletop_regions_0001"
    custom string robosim:csd:worldTemplateId = "env_visual_tabletop_regions"
    custom int64 robosim:randomization:seed = 29

    def Xform "Environment" (
        prepend apiSchemas = ["RobosimEntityAPI"]
    )
    {
        custom string robosim:entity:assetId = "env_visual_tabletop_regions"
        custom string robosim:entity:id = "environment"
        custom token robosim:entity:role = "environment"
        custom bool robosim:entity:static = 1

        def Cube "surface_green_base" (
            prepend apiSchemas = ["RobosimEntityAPI", "PhysicsCollisionAPI", "MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Materials/surface_surface_green_base>
            bool physics:collisionEnabled = 1
            color3f[] primvars:displayColor = [(0.02, 0.8, 0.08)]
            float[] primvars:displayOpacity = [1]
            custom string robosim:entity:assetId = "env_visual_tabletop_regions"
            custom string robosim:entity:id = "surface_green_base"
            custom token robosim:entity:role = "support_surface"
            custom bool robosim:entity:static = 1
            quatd xformOp:orient = (1, 0, 0, 0)
            float3 xformOp:scale = (0.36, 0.42, 0.025)
            double3 xformOp:translate = (0.3, 0, 0.04)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
        }

        def Cube "surface_red_left_pad" (
            prepend apiSchemas = ["RobosimEntityAPI", "PhysicsCollisionAPI", "MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Materials/surface_surface_red_left_pad>
            bool physics:collisionEnabled = 1
            color3f[] primvars:displayColor = [(0.9, 0.04, 0.04)]
            float[] primvars:displayOpacity = [1]
            custom string robosim:entity:assetId = "env_visual_tabletop_regions"
            custom string robosim:entity:id = "surface_red_left_pad"
            custom token robosim:entity:role = "support_surface"
            custom bool robosim:entity:static = 1
            quatd xformOp:orient = (1, 0, 0, 0)
            float3 xformOp:scale = (0.16, 0.12, 0.025)
            double3 xformOp:translate = (0.3, -0.2, 0.095)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
        }

        def Cube "surface_blue_right_pad" (
            prepend apiSchemas = ["RobosimEntityAPI", "PhysicsCollisionAPI", "MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Materials/surface_surface_blue_right_pad>
            bool physics:collisionEnabled = 1
            color3f[] primvars:displayColor = [(0.04, 0.08, 0.9)]
            float[] primvars:displayOpacity = [1]
            custom string robosim:entity:assetId = "env_visual_tabletop_regions"
            custom string robosim:entity:id = "surface_blue_right_pad"
            custom token robosim:entity:role = "support_surface"
            custom bool robosim:entity:static = 1
            quatd xformOp:orient = (1, 0, 0, 0)
            float3 xformOp:scale = (0.16, 0.12, 0.025)
            double3 xformOp:translate = (0.3, 0.2, 0.095)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
        }
    }

    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, 0, -1)
        float physics:gravityMagnitude = 9.81
    }

    def "Materials"
    {
        def Material "surface_surface_green_base" (
            prepend apiSchemas = ["PhysicsMaterialAPI"]
        )
        {
            float physics:dynamicFriction = 1
            float physics:staticFriction = 1
        }

        def Material "surface_surface_red_left_pad" (
            prepend apiSchemas = ["PhysicsMaterialAPI"]
        )
        {
            float physics:dynamicFriction = 1.1
            float physics:staticFriction = 1.1
        }

        def Material "surface_surface_blue_right_pad" (
            prepend apiSchemas = ["PhysicsMaterialAPI"]
        )
        {
            float physics:dynamicFriction = 1.1
            float physics:staticFriction = 1.1
        }

        def Material "object_mug_left" (
            prepend apiSchemas = ["PhysicsMaterialAPI"]
        )
        {
            float physics:dynamicFriction = 0.8
            float physics:staticFriction = 0.8
        }

        def Material "object_tray_right" (
            prepend apiSchemas = ["PhysicsMaterialAPI"]
        )
        {
            float physics:dynamicFriction = 0.7
            float physics:staticFriction = 0.7
        }
    }

    def Camera "overview_camera"
    {
        quatd xformOp:orient = (1, 0, 0, 0)
        quatd xformOp:orient:xyaxes = (0.5958606910503782, 0.38072304482519265, 0.38072304482519265, 0.5958606910503784)
        double3 xformOp:translate = (1.2, 0, 0.75)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:orient:xyaxes"]
    }

    def DistantLight "key_light"
    {
        quatd xformOp:orient = (1, 0, 0, 0)
        double3 xformOp:translate = (0.4, -0.8, 2.6)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient"]
    }

    def Scope "Objects"
    {
        def Xform "mug_left" (
            prepend apiSchemas = ["RobosimEntityAPI", "PhysicsMassAPI", "PhysicsRigidBodyAPI", "MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Materials/object_mug_left>
            float physics:mass = 0.2
            bool physics:rigidBodyEnabled = 1
            custom string robosim:entity:assetId = "object_mug"
            custom string robosim:entity:id = "mug_left"
            custom token robosim:entity:role = "interactive_object"
            custom bool robosim:entity:static = 0
            quatd xformOp:orient = (1, 0, 0, 0)
            double3 xformOp:translate = (0.28, -0.2, 0.18)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient"]
        }

        def Xform "tray_right" (
            prepend apiSchemas = ["RobosimEntityAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Materials/object_tray_right>
            float physics:mass = 1
            custom string robosim:entity:assetId = "object_tray"
            custom string robosim:entity:id = "tray_right"
            custom token robosim:entity:role = "receptacle"
            custom bool robosim:entity:static = 1
            quatd xformOp:orient = (1, 0, 0, 0)
            double3 xformOp:translate = (0.32, 0.2, 0.14)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient"]
        }
    }

    def Scope "Task" (
        prepend apiSchemas = ["RobosimTaskAPI"]
    )
    {
        custom string robosim:task:objective = "verify that the compiler preserves distinct background, support, and object placement semantics"
    }

    def Scope "Relationships"
    {
        def RobosimRelationship "rel_mug_on_red_pad"
        {
            custom double robosim:relationship:minDistanceM = 0
            custom rel robosim:relationship:object = </World/Environment/surface_red_left_pad>
            custom rel robosim:relationship:subject = </World/Objects/mug_left>
            custom double robosim:relationship:tolerance = 0.04
            custom token robosim:relationship:type = "on_top_of"
        }

        def RobosimRelationship "rel_tray_on_blue_pad"
        {
            custom double robosim:relationship:minDistanceM = 0
            custom rel robosim:relationship:object = </World/Environment/surface_blue_right_pad>
            custom rel robosim:relationship:subject = </World/Objects/tray_right>
            custom double robosim:relationship:tolerance = 0.04
            custom token robosim:relationship:type = "on_top_of"
        }
    }
    variantSet "physicsBackend" = {
        "gazebo" {

        }
        "mujoco" {

        }
        "pybullet" {

        }
    }
}

